# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (NEVER commit actual .env files)
.env
.env.local
.env.*.local

# C# appsettings with sensitive data
appsettings.json
appsettings.Development.json
appsettings.Local.json

.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

NexumAPI/publish/

publish/
